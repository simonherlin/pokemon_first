; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes in []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pokemon Rouge Bleu HD"
config/description="Recréation familiale de Pokémon Rouge/Bleu en version HD modernisée."
run/main_scene="res://scenes/title_screen.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://assets/sprites/ui/icon.png"

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
PlayerData="*res://scripts/autoload/player_data.gd"
SceneManager="*res://scripts/autoload/scene_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
SpeciesData="*res://scripts/pokemon/species_data.gd"
MoveData="*res://scripts/pokemon/move_data.gd"
EncounterSystem="*res://scripts/overworld/encounter_system.gd"
BattleCalculator="*res://scripts/battle/battle_calculator.gd"
MoveEffects="*res://scripts/battle/move_effects.gd"
AIController="*res://scripts/battle/ai_controller.gd"
BattleController="*res://scripts/battle/battle_controller.gd"
MapLoader="*res://scripts/overworld/map_loader.gd"
TileSetBuilder="*res://scripts/overworld/tileset_builder.gd"
ItemsData="*res://scripts/autoload/items_data.gd"
QuestManager="*res://scripts/autoload/quest_manager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=320
window/size/initial_width=960
window/size/initial_height=640
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

